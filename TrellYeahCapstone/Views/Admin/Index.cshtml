@model TrellYeahCapstone.Models.AdminIndexViewModel

@{
    ViewData["Title"] = "Admin";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h2 mb-0">Admin</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-controller="Admin" asp-action="AddCollege">Add college</a>
        <a class="btn btn-outline-primary" asp-controller="Admin" asp-action="AddDepartment">Add department</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

<section class="mb-4">
    <h2 class="h4">ARCC Committee</h2>

    <div class="mb-4">
        <h3 class="h5">Existing members</h3>
        @if (Model.ArccCommitteeMembers.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Chair</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.ArccCommitteeMembers)
                    {
                        <tr>
                            <td>@($"{user.FirstName} {user.LastName}".Trim())</td>
                            <td>@(user.Email ?? user.UserName)</td>
                            <td>
                                @if (user.IsArccCommitteeChair)
                                {
                                    <span class="badge bg-primary">Chair</span>
                                }
                                else
                                {
                                    <form asp-action="SetArccCommitteeChair" method="post">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Make chair</button>
                                    </form>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="RemoveArccCommitteeMember" method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No ARCC committee members have been added yet.</p>
        }
    </div>

    <div>
        <h3 class="h5">Add members</h3>
        @if (Model.AvailableArccUsers.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.AvailableArccUsers)
                    {
                        <tr>
                            <td>@($"{user.FirstName} {user.LastName}".Trim())</td>
                            <td>@(user.Email ?? user.UserName)</td>
                            <td class="text-end">
                                <form asp-action="AddArccCommitteeMember" method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Add to committee</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>All users are currently on the ARCC committee.</p>
        }
    </div>
</section>

<section class="mb-4">
    <h2 class="h4">Colleges</h2>
    @if (Model.Colleges.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Dean</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var college in Model.Colleges)
                {
                    <tr>
                        <td>@college.Name</td>
                        <td>@Model.UserEmails.GetValueOrDefault(college.DeanUserId, college.DeanUserId)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No colleges have been added yet.</p>
    }
</section>

<section>
    <h2 class="h4">Departments</h2>
    @if (Model.Departments.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>College</th>
                    <th>Chair</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var department in Model.Departments)
                {
                    <tr>
                        <td>@department.Name</td>
                        <td>@department.College?.Name</td>
                        <td>@Model.UserEmails.GetValueOrDefault(department.ChairUserId, department.ChairUserId)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No departments have been added yet.</p>
    }
</section>
