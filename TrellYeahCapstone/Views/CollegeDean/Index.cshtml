@model List<TrellYeahCapstone.Models.GrantReviewSummaryViewModel>

@{
    ViewData["Title"] = "College Dean Review";
    var pending = Model.Where(g => g.Status == "Approved by Department Chair").ToList();
    var processed = Model.Where(g => g.Status != "Approved by Department Chair").ToList();
}

<h1>College Dean Review</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<h2 class="h4 mt-3">Pending Review</h2>
@if (!pending.Any())
{
    <div class="alert alert-info">No grant applications are waiting for your college's approval.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Grant title</th>
                <th>Principal investigator</th>
                <th>College funds requested</th>
                <th>Submitted</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var grant in pending)
            {
                <tr>
                    <td>@grant.Title</td>
                    <td>@grant.PrincipalInvestigatorName</td>
                    <td>@grant.MoneyRequestedFromCollege.ToString("C")</td>
                    <td>@(grant.SubmittedAt?.ToString("MMM d, yyyy h:mm tt") ?? "Not submitted")</td>
                    <td class="text-end">
                        <a asp-controller="CollegeDean" asp-action="Review" asp-route-id="@grant.GrantId"
                           class="btn btn-sm btn-outline-primary">View Application</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h2 class="h4 mt-4">Processed</h2>
@if (!processed.Any())
{
    <div class="alert alert-info">No grants have been approved or rejected yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Grant title</th>
                <th>Principal investigator</th>
                <th>College funds requested</th>
                <th>Submitted</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var grant in processed)
            {
                <tr>
                    <td>@grant.Title</td>
                    <td>@grant.PrincipalInvestigatorName</td>
                    <td>@grant.MoneyRequestedFromCollege.ToString("C")</td>
                    <td>@(grant.SubmittedAt?.ToString("MMM d, yyyy h:mm tt") ?? "Not submitted")</td>
                    <td>
                        @if (grant.Status.Contains("Approved"))
                        {
                            <span class="badge text-bg-success">@grant.Status</span>
                        }
                        else
                        {
                            <span class="badge text-bg-danger">@grant.Status</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
