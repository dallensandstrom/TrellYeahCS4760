@model TrellYeahCapstone.Models.AllocationViewModel

@{
    ViewData["Title"] = "Grant Allocation";
}

<h1>Grant Allocation</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<section class="mb-5">
    <h2 class="h4">Submitted Grant Applications</h2>
    @if (!Model.SubmittedGrants.Any())
    {
        <div class="alert alert-info">No submitted applications are ready for allocation.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Principal investigator</th>
                        <th>Requested from ARCC</th>
                        <th>Requested from other sources</th>
                        <th>Average score</th>
                        <th>Allocated money</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grant in Model.SubmittedGrants)
                    {
                        <tr>
                            <td>@grant.Title</td>
                            <td>@grant.PrincipalInvestigatorName</td>
                            <td>@grant.MoneyRequestedFromArcc.ToString("C")</td>
                            <td>@grant.MoneyRequestedFromOtherSources.ToString("C")</td>
                            <td>
                                @if (grant.AverageScorePercentage.HasValue)
                                {
                                    <span>@grant.AverageScorePercentage.Value.ToString("0.##")%</span>
                                    <span class="text-muted">(@grant.ReviewerCount reviewer@(grant.ReviewerCount == 1 ? "" : "s"))</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not reviewed</span>
                                }
                            </td>
                            <td>
                                @if (grant.AllocatedAmount.HasValue)
                                {
                                    <span>@grant.AllocatedAmount.Value.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not allocated</span>
                                }
                            </td>
                            <td>@grant.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="mb-5">
    <h2 class="h4">Rejected Applications</h2>
    @if (!Model.RejectedGrants.Any())
    {
        <div class="alert alert-info">No applications have been rejected by the ARCC cutoff.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Principal investigator</th>
                        <th>Requested from ARCC</th>
                        <th>Requested from other sources</th>
                        <th>Average score</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grant in Model.RejectedGrants)
                    {
                        <tr>
                            <td>@grant.Title</td>
                            <td>@grant.PrincipalInvestigatorName</td>
                            <td>@grant.MoneyRequestedFromArcc.ToString("C")</td>
                            <td>@grant.MoneyRequestedFromOtherSources.ToString("C")</td>
                            <td>
                                @if (grant.AverageScorePercentage.HasValue)
                                {
                                    <span>@grant.AverageScorePercentage.Value.ToString("0.##")%</span>
                                    <span class="text-muted">(@grant.ReviewerCount reviewer@(grant.ReviewerCount == 1 ? "" : "s"))</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not reviewed</span>
                                }
                            </td>
                            <td>@grant.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="mb-5">
    <h2 class="h4">Grant Allocation Criteria</h2>
    <p class="text-muted">Define score ranges and what percentage of the requested ARCC amount each range receives. Click <strong>Apply Criteria</strong> to compute and save allocated amounts for submitted grants.</p>

    @if (!Model.AllocationCriteria.Any())
    {
        <div class="alert alert-info">No criteria defined yet. Add one below.</div>
    }
    else
    {
        <table class="table table-striped align-middle mb-3">
            <thead>
                <tr>
                    <th>Min score %</th>
                    <th>Max score %</th>
                    <th>Allocation %</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var criterion in Model.AllocationCriteria)
                {
                    <tr>
                        <td>@criterion.MinScorePercentage.ToString("0.##")%</td>
                        <td>@criterion.MaxScorePercentage.ToString("0.##")%</td>
                        <td>@criterion.AllocationPercentage.ToString("0.##")%</td>
                        <td>
                            <form asp-action="DeleteCriterion" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@criterion.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="ApplyCriteria" method="post" class="mb-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Apply Criteria</button>
        </form>
    }

    <h3 class="h5 mt-3">Add a criterion</h3>
    <form asp-action="AddCriterion" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label asp-for="NewCriterionMinScore" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="NewCriterionMinScore" class="form-control" type="number" min="0" max="100" step="0.01" style="width:100px" />
                    <span class="input-group-text">%</span>
                </div>
            </div>
            <div class="col-auto">
                <label asp-for="NewCriterionMaxScore" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="NewCriterionMaxScore" class="form-control" type="number" min="0" max="100" step="0.01" style="width:100px" />
                    <span class="input-group-text">%</span>
                </div>
            </div>
            <div class="col-auto">
                <label asp-for="NewCriterionAllocationPercentage" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="NewCriterionAllocationPercentage" class="form-control" type="number" min="0" max="100" step="0.01" style="width:100px" />
                    <span class="input-group-text">%</span>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Add criterion</button>
            </div>
        </div>
    </form>
</section>

<section>
    <h2 class="h4">Grant Allocation Cutoff Percentage</h2>
    <p class="text-muted">The cutoff only rejects applications that already have at least one ARCC rubric review.</p>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Allocation" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CurrentRoundAmount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="CurrentRoundAmount" class="form-control" type="number" min="0" step="0.01" />
                </div>
                <span asp-validation-for="CurrentRoundAmount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PreviousRoundAmount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="PreviousRoundAmount" class="form-control" type="number" min="0" step="0.01" />
                </div>
                <span asp-validation-for="PreviousRoundAmount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CutoutPercentage" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="CutoutPercentage" class="form-control" type="number" min="0" max="100" step="0.01" />
                    <span class="input-group-text">%</span>
                </div>
                <span asp-validation-for="CutoutPercentage" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Apply cutoff percentage</button>
        </form>
    </div>
</div>
</section>

<section class="mt-5">
    <h2 class="h4">Past Submitted Allocations</h2>
    @if (!Model.PastAllocations.Any())
    {
        <div class="alert alert-info">No allocations have been submitted yet.</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Submitted</th>
                    <th>Current Round</th>
                    <th>Previous Round</th>
                    <th>Cutout %</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.PastAllocations)
                {
                    <tr>
                        <td>@a.CreatedAt.ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@a.CurrentRoundAmount.ToString("C")</td>
                        <td>@a.PreviousRoundAmount.ToString("C")</td>
                        <td>@a.CutoutPercentage.ToString("0.##")%</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
