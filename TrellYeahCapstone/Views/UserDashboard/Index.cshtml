@model TrellYeahCapstone.Models.UserDashboardViewModel

@{
    ViewData["Title"] = "User Dashboard";
}

<h1>User Dashboard</h1>

<div class="d-flex gap-2 mb-3">
    <a asp-controller="Rubric" asp-action="ViewRubric" class="btn btn-outline-primary">
        View Rubric
    </a>

    <a asp-controller="Grants" asp-action="Create" class="btn btn-primary">
        Start New Grant Application
    </a>
</div>

<section>
    <h2 class="h4">My Grant Applications</h2>

    @if (!Model.UserGrants.Any())
    {
        <div class="alert alert-info">
            You have not started any grant applications yet.
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grant in Model.UserGrants)
                {
                    <tr>
                        <td>@grant.Title</td>
                        <td>@grant.Status</td>
                        <td>
                            @(grant.SubmittedAt.HasValue
                                ? grant.SubmittedAt.Value.ToString("MMM d, yyyy h:mm tt")
                                : "Not submitted")
                        </td>
                        <td>
                            <a asp-controller="Grants" asp-action="Details" asp-route-id="@grant.GrantId" class="btn btn-sm btn-outline-secondary">
                                View
                            </a>

                            @if (grant.Status == "In Progress")
                            {
                                <a asp-controller="Grants" asp-action="Edit" asp-route-id="@grant.GrantId" class="btn btn-sm btn-primary">
                                    Continue Editing
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" disabled title="@grant.Status">
                                    Locked
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
