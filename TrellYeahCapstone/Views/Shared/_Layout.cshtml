<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrellYeahCapstone</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrellYeahCapstone.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark wsu-navbar mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TrellYeahCapstone</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">Admin</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("ARCCchair"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Rubric" asp-action="Index">Rubric</a>
                            </li>
                        }
                        @if (User.IsInRole("ARCCmember") || User.IsInRole("ARCCchair"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UserDashboard" asp-action="Review">Review</a>
                            </li>
                        }
                        @if (User.IsInRole("ARCCchair"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UserDashboard" asp-action="Allocation">Allocation</a>
                            </li>
                        }
                        @if (User.IsInRole("DeptChair"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="DepartmentChair"
                                   asp-action="Index">
                                    Department Review
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("CollegeDean"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="CollegeDean"
                                   asp-action="Index">
                                    College Dean Review
                                </a>
                            </li>
                        }
                        @if (User.Identity != null &&
                             User.Identity.IsAuthenticated &&
                             !User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="UserDashboard" asp-action="Index">Dashboard</a>
                                </li>
                            }
                        </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            Team Trell Yeah Redux - Aidan Olson, Dallen Sandstrom, Dylan Stout, Julie Nguyen
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
