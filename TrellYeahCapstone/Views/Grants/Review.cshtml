@model TrellYeahCapstone.Models.GrantReviewDetailsViewModel

@{
    ViewData["Title"] = "Review Grant Application";
    var grant = Model.Grant;
    var totalCollege = grant.BudgetItems.Sum(item => item.CollegeAmount);
    var totalDepartment = grant.BudgetItems.Sum(item => item.DepartmentAmount);
    var totalOther = grant.BudgetItems.Sum(item => item.OtherAmount);
    var grandTotal = Model.MoneyRequestedFromArcc + totalCollege + totalDepartment + totalOther;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h2 mb-1">Review Grant Application</h1>
        <p class="text-muted mb-0">@grant.Title</p>
    </div>
    <a asp-controller="UserDashboard" asp-action="Review" class="btn btn-outline-secondary">
        Back
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
}

<div class="row g-4 align-items-start">
    <div class="col-lg-7">
        <section class="mb-4">
            <h2 class="h4">Application Summary</h2>
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th style="width: 260px;">Grant title</th>
                        <td>@grant.Title</td>
                    </tr>
                    <tr>
                        <th>Project director</th>
                        <td>@Model.ProjectDirectorName</td>
                    </tr>
                    <tr>
                        <th>Principal investigator</th>
                        <td>@Model.PrincipalInvestigatorName</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>@grant.Status</td>
                    </tr>
                    <tr>
                        <th>Submitted</th>
                        <td>@(grant.SubmittedAt?.ToString("MMM d, yyyy h:mm tt") ?? "Not submitted")</td>
                    </tr>
                    <tr>
                        <th>Money requested from ARCC</th>
                        <td>@Model.MoneyRequestedFromArcc.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </section>

        @if (!string.IsNullOrWhiteSpace(grant.DeptChairApprovalNotes) || !string.IsNullOrWhiteSpace(grant.DeanApprovalNotes))
        {
            <section class="mb-4">
                <h2 class="h4">Approval / Rejection Notes</h2>

                @if (!string.IsNullOrWhiteSpace(grant.DeptChairApprovalNotes))
                {
                    <div class="alert alert-secondary">
                        <strong>Department Chair Notes:</strong><br />
                        @grant.DeptChairApprovalNotes
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(grant.DeanApprovalNotes))
                {
                    <div class="alert alert-secondary">
                        <strong>College Dean Notes:</strong><br />
                        @grant.DeanApprovalNotes
                    </div>
                }
            </section>
        }

        <section class="mb-4">
            <h2 class="h4">Project Information</h2>
            <dl class="row">
                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@grant.Description</dd>

                <dt class="col-sm-4">Justification</dt>
                <dd class="col-sm-8">@grant.Justification</dd>
                <dt class="col-sm-4">Account Number</dt>
                <dd class="col-sm-8">@grant.AccountNumber</dd>

                <dt class="col-sm-4">Timeline</dt>
                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(grant.Timeline) ? "Not provided" : grant.Timeline)</dd>

                <dt class="col-sm-4">Students benefited</dt>
                <dd class="col-sm-8">@grant.WeberStateStudentsBenefited</dd>

                <dt class="col-sm-4">Benefits multiple departments</dt>
                <dd class="col-sm-8">@(grant.BenefitsMultipleDepartments ? "Yes" : "No")</dd>

                <dt class="col-sm-4">Departments benefited</dt>
                <dd class="col-sm-8">@(grant.NumberOfDepartmentsBenefited?.ToString() ?? "Not applicable")</dd>

                <dt class="col-sm-4">Uses human subjects</dt>
                <dd class="col-sm-8">@(grant.UsesHumanSubjects ? "Yes" : "No")</dd>
            </dl>
        </section>

        <section class="mb-4">
            <h2 class="h4">Applicant Agreements</h2>

            <dl class="row">
                <dt class="col-sm-4">Agreement One</dt>
                <dd class="col-sm-8">@(grant.AgreementOne ? "Agreed" : "Not Agreed")</dd>

                <dt class="col-sm-4">Agreement Two</dt>
                <dd class="col-sm-8">@(grant.AgreementTwo ? "Agreed" : "Not Agreed")</dd>

                <dt class="col-sm-4">Agreement Three</dt>
                <dd class="col-sm-8">@(grant.AgreementThree ? "Agreed" : "Not Agreed")</dd>

                <dt class="col-sm-4">Agreement Four</dt>
                <dd class="col-sm-8">@(grant.AgreementFour ? "Agreed" : "Not Agreed")</dd>

                <dt class="col-sm-4">Electronic Signature</dt>
                <dd class="col-sm-8">@grant.ApplicationSignature</dd>
            </dl>
        </section>

        <section class="mb-4">
            <h2 class="h4">Budget</h2>
            @if (grant.BudgetItems.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qty</th>
                                <th>Type</th>
                                <th>ARCC</th>
                                <th>College</th>
                                <th>Department</th>
                                <th>Other</th>
                                <th>Other source</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in grant.BudgetItems)
                            {
                                <tr>
                                    <td>@item.ItemName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.ItemType</td>
                                    <td>@item.ARCCAmount.ToString("C")</td>
                                    <td>@item.CollegeAmount.ToString("C")</td>
                                    <td>@item.DepartmentAmount.ToString("C")</td>
                                    <td>@item.OtherAmount.ToString("C")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.OtherSource) ? "-" : item.OtherSource)</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3">Totals</th>
                                <th>@Model.MoneyRequestedFromArcc.ToString("C")</th>
                                <th>@totalCollege.ToString("C")</th>
                                <th>@totalDepartment.ToString("C")</th>
                                <th>@totalOther.ToString("C")</th>
                                <th>Grand total: @grandTotal.ToString("C")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <p>No budget items were included.</p>
            }
        </section>

        <section>
            <h2 class="h4">Files</h2>
            @if (Model.FileLinks.Any())
            {
                <ul class="list-group">
                    @foreach (var file in Model.FileLinks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@file.Label</span>
                            <a href="@Url.Content(file.Url)" class="btn btn-sm btn-outline-primary" download>
                                Download
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No files were uploaded with this application.</p>
            }
        </section>
    </div>



    <div class="col-lg-5">
        <section class="position-sticky" style="top: 1rem;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h2 class="h4 mb-0">Rubric Rating</h2>
                <span class="badge text-bg-secondary">@Model.SelectedScoreTotal / @Model.PossibleScoreTotal</span>
            </div>

            @if (Model.RubricScores.Any())
            {
                <form asp-controller="Grants" asp-action="SaveReviewScores" asp-route-id="@grant.GrantId" method="post">
                    @foreach (var criterion in Model.RubricScores)
                    {
                        <div class="border rounded p-3 mb-3">
                            <div class="d-flex align-items-start justify-content-between gap-3">
                                <div>
                                    <h3 class="h5 mb-1">@criterion.Name</h3>
                                    <p class="text-muted mb-2">@criterion.Description</p>
                                </div>
                                <span class="badge text-bg-light border">@criterion.MaximumScore max</span>
                            </div>

                            <label class="form-label" for="score-@criterion.RubricCriterionId">Score</label>
                            <select class="form-select"
                                    id="score-@criterion.RubricCriterionId"
                                    name="scores[@criterion.RubricCriterionId]"
                                    required>
                                <option value="">Select a score</option>
                                @foreach (var suggestion in criterion.RatingSuggestions)
                                {
                                    if (criterion.SelectedScore == suggestion.Score)
                                    {
                                        <option value="@suggestion.Score" selected>@suggestion.Score pts - @suggestion.Description</option>
                                    }
                                    else
                                    {
                                        <option value="@suggestion.Score">@suggestion.Score pts - @suggestion.Description</option>
                                    }
                                }
                            </select>
                        </div>
                    }

                    <div class="border-top pt-3 mt-3">
                        <div class="d-flex justify-content-between">
                            <span class="fw-semibold">Final rating</span>
                            <span class="fw-semibold">@Model.SelectedScoreTotal / @Model.PossibleScoreTotal</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted">
                            <span>Percentage</span>
                            <span>@Model.ScorePercentage.ToString("0.##")%</span>
                        </div>
                    </div>
                    @if (User.IsInRole("ARCCchair"))
                    {
                        <div class="mb-3">
                            <label for="arccChairApprovalNotes" class="form-label">ARCC Chair Notes (Optional)</label>
                            <textarea id="arccChairApprovalNotes"
                                      name="arccChairApprovalNotes"
                                      class="form-control"
                                      rows="3">@grant.ArccChairApprovalNotes</textarea>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary w-100 mt-3">Save Rating</button>
                </form>
            }
            else
            {
                <p class="text-muted">No rubric criteria have been created yet.</p>
            }
        </section>
    </div>
</div>
