@model TrellYeahCS4760.Models.Grant

@{
    ViewData["Title"] = "Grant Details";
}

<h1>Grant Details</h1>

<div class="card">
    <div class="card-body">
        <h4>@Model.Title</h4>

        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Justification:</strong> @Model.Justification</p>
		<p><strong>Account Number:</strong> @Model.AccountNumber</p>
        <p><strong>Timeline:</strong> @Model.Timeline</p>
		<p><strong>Agreement One:</strong> @(Model.AgreementOne ? "Yes" : "No")</p>
		<p><strong>Agreement Two:</strong> @(Model.AgreementTwo ? "Yes" : "No")</p>
		<p><strong>Agreement Three:</strong> @(Model.AgreementThree ? "Yes" : "No")</p>
		<p><strong>Agreement Four:</strong> @(Model.AgreementFour ? "Yes" : "No")</p>
		<p><strong>Application Signature:</strong> @Model.ApplicationSignature</p>
        <p><strong>Submitted:</strong> @(Model.SubmittedAt?.ToString("MMM d, yyyy h:mm tt") ?? "Not submitted")</p>
		@if (!string.IsNullOrWhiteSpace(Model.DeptChairApprovalNotes))
		{
			<p>
				<strong>Department Chair Notes:</strong>
				@Model.DeptChairApprovalNotes
			</p>
		}

		@if (!string.IsNullOrWhiteSpace(Model.DeanApprovalNotes))
		{
			<p>
				<strong>College Dean Notes:</strong>
				@Model.DeanApprovalNotes
			</p>
		}
		@if (!string.IsNullOrWhiteSpace(Model.ArccChairApprovalNotes))
		{
			<p>
				<strong>ARCC Chair Notes:</strong>
				@Model.ArccChairApprovalNotes
			</p>
		}
    </div>
</div>

<a asp-controller="UserDashboard" asp-action="Index" class="btn btn-secondary mt-3">
    Back to Dashboard
</a>

@if (Model.Status != "Submitted")
{
    <a asp-controller="Grants" asp-action="Edit" asp-route-id="@Model.GrantId" class="btn btn-primary mt-3">
        Continue Editing
    </a>
}

